{% extends 'layouts/base.html.twig' %}

{% block title %}
	Fonds d'archives &middot;
	{{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/css/scrollbar.css') }}">

	<style>
		body {
			background-color: #f9fbfd;
			overflow: hidden;
		}

		.flash-msg {
			display: none;
			opacity: 0;
			transition: opacity 0.5s ease;
		}

		.flash-msg.show {
			display: block;
			opacity: 1;
		}

		#notification-card:hover {
			background-color: #E9F3FF;
		}

		.rejectComment-input {
			flex-wrap: wrap;
			padding: 0.5rem;
			border: 1px solid #ced4da;
			border-radius: 0.25rem;
			height: 150px;
		}
		.rejectComment-input textarea {
			border: none;
			outline: none;
			width: 100%;
			height: 100%;
			min-height: 100%;
			max-height: 100%;
			flex-grow: 1;
		}
	</style>

{% endblock %}

