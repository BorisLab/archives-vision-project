{% extends 'layouts/base.html.twig' %}

{% block title %}
	Inscription &middot;
	{{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}">

	<style>
		body {
			background-color: #f9fbfd;
		}

		.main-content {
			overflow-x: hidden;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="main-content">
		{{ include('layouts/partials/admin/_navbar-admin.html.twig') }}
		<div class="logout-div" style="display:none">
			<div id="loading-overlay" class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="display: none; background-color: rgba(255, 255, 255, 0.8);">
				<div class="text-center">
					<div class="spinner-border text-primary" role="status">
						<span class="visually-hidden">Loading...</span>
					</div>
					<p class="mt-2">Déconnexion en cours...</p>
				</div>
			</div>
		</div>
		<div class="load-div" style="display:none">
			<div id="loading-overlay" class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="display: none; background-color: rgba(255, 255, 255, 0.8);">
				<div class="text-center">
					<div class="spinner-border text-primary" role="status">
						<span class="visually-hidden">Loading...</span>
					</div>
					<p class="mt-2">Veuillez patienter...</p>
				</div>
			</div>
		</div>
		<div class="container mt-5">
			<div class="card shadow border">
				<div class="card-body">
					<div class="row justify-content-center">
						<div class="col-12">
							<div class="col-md-12 mx-auto">
								<div class="card-header">
									<h3 class="card-title text-center text-body-secondary mb-3">Inscrire un nouvel utilisateur</h3>
								</div>

								{{ form_start(registrationForm) }}
								<div class="container mt-4">
									<div class="row">
										<div class="col">
											{{ form_row(registrationForm.nom) }}
										</div>
										<div class="col">
											{{ form_row(registrationForm.prenoms, {
                                               label: 'Prénom(s)',
                                            }) }}
										</div>
									</div>
									<div class="row">
										<div class="col">
											{{ form_row(registrationForm.email) }}
										</div>
										<div class="col">
											{{ form_row(registrationForm.plainPassword, {
                                                label: 'Mot de passe'
                                            }) }}
										</div>
									</div>
									<div class="row">
										<div class="col">
											{{ form_row(registrationForm.departement , {
                                                label: 'Département',
                                            })  }}
										</div>
										<div class="col">
											{{ form_row(registrationForm.roles) }}
										</div>
									</div>
									<div class="d-flex justify-content-between">
										{{ form_row(registrationForm.agreeTerms, {
                                            label: 'Accepter les conditions d\'utilisation'
                                        }) }}
      </div>

      <div class="d-grid gap-2">
           <button type="submit" class="btn btn-lg btn-info mb-3"><span style="font-size:17px">Valider l'inscription</span></button>
      </div>
    </div>
    {{ form_end(registrationForm) }}

									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		{% endblock %}
