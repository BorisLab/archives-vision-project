<style>

	body {
		background-color: #f9fbfd;
		overflow-x: hidden;
	}

	input.form-control:focus,
	.form-select:focus {
		border-color: #0d6efd;
		outline: 0;
		box-shadow: 0 0 0 0;
	}
</style>
<div class="table-wrapper" style="max-height:500px;overflow-x:hidden;overflow-y:auto">
	<table class="table table-sm">
		<thead class="bg-secondary-subtle">
			<tr>
				<th>
					<span href="#" class="link-dark">Nom</span>
				</th>
				<th>
					<span href="#" class="link-dark">Format</span>
				</th>
				<th>
					<span href="#" class="link-dark">Département</span>
				</th>
				<th>
					<span href="#" class="link-dark">Mots-clés</span>
				</th>
				<th>
					<span href="#" class="link-dark">Date de création</span>
				</th>
				<th>
					<span href="#" class="link-dark">Statut</span>
				</th>
				<th class="text-center pe-5">
					<span class="text-dark">Actions</span>
				</th>
			</tr>
		</thead>
		<tbody class="list">
			{% if dossier_courant %}
				{% if dossier_courant.dossierParent %}
					<tr class="item-row">
						<td class="tables-first" colspan="7">
							<a class="link-dark" href="{{ path('app_user_folder_content', {id: dossier_courant.dossierParent.dossierId}) }}">
								<div>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-return-left" viewbox="0 0 16 16">
										<path fill-rule="evenodd" d="M14.5 1.5a.5.5 0 0 1 .5.5v4.8a2.5 2.5 0 0 1-2.5 2.5H2.707l3.347 3.346a.5.5 0 0 1-.708.708l-4.2-4.2a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 8.3H12.5A1.5 1.5 0 0 0 14 6.8V2a.5.5 0 0 1 .5-.5"/>
									</svg>
									<span class="">. . Retour</span>
								</div>
							</a>
						</td>
					</tr>
				{% else %}
					<tr class="item-row">
						<td class="tables-first" colspan="7">
							<a class="link-dark" href="{{ path('app_user_home') }}">
								<div>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-return-left" viewbox="0 0 16 16">
										<path fill-rule="evenodd" d="M14.5 1.5a.5.5 0 0 1 .5.5v4.8a2.5 2.5 0 0 1-2.5 2.5H2.707l3.347 3.346a.5.5 0 0 1-.708.708l-4.2-4.2a.5.5 0 0 1 0-.708l4-4a.5.5 0 1 1 .708.708L2.707 8.3H12.5A1.5 1.5 0 0 0 14 6.8V2a.5.5 0 0 1 .5-.5"/>
									</svg>
									<span class="">. . Retour</span>
								</div>
							</a>
						</td>
					</tr>
				{% endif %}
			{% endif %}
			{% if dossiers is empty and fichiers is empty %}
				<tr class="empty-list">
					<td
						colspan="7">

						<!-- Title -->
						<h4 class="mt-2 mb-2 text-center">
							Aucun document pour l'instant
						</h4>

						<!-- Content -->
						<p class="text-muted text-center">
							Tous vos documents d'archives produits s'afficheront ici.
						</p>
					</td>
				</tr>
			{% endif %}
			{%for dossier in dossiers %}
				<tr class="item-row">
					<td class="tables-first text-truncate" style="max-width:200px">
						<svg style="padding-bottom:3px" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-folder-fill" viewbox="0 0 16 16">
							<path d="M9.828 3h3.982a2 2 0 0 1 1.992 2.181l-.637 7A2 2 0 0 1 13.174 14H2.825a2 2 0 0 1-1.991-1.819l-.637-7a2 2 0 0 1 .342-1.31L.5 3a2 2 0 0 1 2-2h3.672a2 2 0 0 1 1.414.586l.828.828A2 2 0 0 0 9.828 3m-8.322.12q.322-.119.684-.12h5.396l-.707-.707A1 1 0 0 0 6.172 2H2.5a1 1 0 0 0-1 .981z"/>
						</svg>
						<a id="item-name" class="link-dark" title="{{ dossier.libelledossier }}" href="{{ path('app_user_folder_content', {id: dossier.dossierId})}}">{{ dossier.libelledossier }}</a>
					</td>
					<td class="tables-last text-truncate" style="max-width:200px">{{ dossier.format }}</td>
					<td class="tables-handle text-truncate" style="max-width:200px">{{ dossier.departement.libelleDep }}</td>
					{% if dossier.tags == null %}
						<td class="tables-tags fst-italic text-secondary text-truncate" style="max-width:200px">Aucun mot-clé</td>
					{% else %}
						<td class="tables-tags text-truncate" style="max-width:200px">{{ dossier.getFormattedTags }}</td>
					{% endif %}
					<td class="tables-date">{{ dossier.dateCreation|date('d/m/Y') }}</td>
					{% if dossier.statut == 1 %}
						<td class="tables-handle text-success">Disponible</td>
					{% else %}
						<td class="tables-handle text-danger">Indisponible</td>
					{% endif %}
					<td class="text-center">
						<span>
							<form method="POST">
								<input type="hidden" name="_action" value="reqDossier">
								<input type="hidden" id="reqDossierId" name="reqDossierId">
								{% for da in demandesacces %}
									{% if da.dossier.dossierid == dossier.dossierid and da.statut == 'pending' %}
										<button type="button" id="btn-req-folder" class="btn btn-outline-dark accordion-edit btn-sm rounded-sm text-center" disabled style="font-size:13px;width:75%">
											<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" class="bi bi-question-circle-fill mb-1 me-1" viewbox="0 0 16 16">
												<path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.496 6.033h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286a.237.237 0 0 0 .241.247m2.325 6.443c.61 0 1.029-.394 1.029-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94 0 .533.425.927 1.01.927z"/>
											</svg>
											En attente...
										</button>
									{% else %}
										<button type="submit" id="btn-req-folder" class="btn btn-outline-dark accordion-edit btn-sm rounded-sm text-center" {{ dossier.statut ? '' : 'disabled' }} style="font-size:13px;width:75%" data-id="{{ dossier.dossierId }}">
											<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" class="bi bi-lock-fill mb-1" viewbox="0 0 16 16">
												<path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2"/>
											</svg>
											Demander accès
										</button>
									{% endif %}
								{% endfor %}
								{% if demandesacces == NULL %}
									<button type="submit" id="btn-req-folder" class="btn btn-outline-dark accordion-edit btn-sm rounded-sm text-center" {{ dossier.statut ? '' : 'disabled' }} style="font-size:13px;width:75%" data-id="{{ dossier.dossierId }}">
										<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" class="bi bi-lock-fill mb-1" viewbox="0 0 16 16">
											<path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2"/>
										</svg>
										Demander accès
									</button>
								{% endif %}
							</form>
						</span>
					</td>
				</tr>
			{% endfor %}
			{% if fichiers %}
				{% for fichier in fichiers %}
					<tr class="item-row">
						<td class="tables-first text-truncate" style="max-width:200px">
							{% if fichier.type == 'Document' %}
								<svg class="padding-bottom:4px" xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" class="bi bi-file-earmark-text" viewbox="0 0 16 16">
									<path d="M5.5 7a.5.5 0 0 0 0 1h5a.5.5 0 0 0 0-1zM5 9.5a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0 2a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5"/>
									<path d="M9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V4.5zm0 1v2A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/>
								</svg>
							{% elseif fichier.type == 'Image' %}
								<svg class="padding-bottom:4px" xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" class="bi bi-file-earmark-image" viewbox="0 0 16 16">
									<path d="M6.502 7a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3"/>
									<path d="M14 14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zM4 1a1 1 0 0 0-1 1v10l2.224-2.224a.5.5 0 0 1 .61-.075L8 11l2.157-3.02a.5.5 0 0 1 .76-.063L13 10V4.5h-2A1.5 1.5 0 0 1 9.5 3V1z"/>
								</svg>
							{% elseif fichier.type == 'Vidéo' %}
								<svg class="padding-bottom:4px" xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" class="bi bi-file-earmark-play" viewbox="0 0 16 16">
									<path d="M6 6.883v4.234a.5.5 0 0 0 .757.429l3.528-2.117a.5.5 0 0 0 0-.858L6.757 6.454a.5.5 0 0 0-.757.43z"/>
									<path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
								</svg>
							{% elseif fichier.type == 'Audio' %}
								<svg class="padding-bottom:4px" xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="currentColor" class="bi bi-file-earmark-music" viewbox="0 0 16 16">
									<path d="M11 6.64a1 1 0 0 0-1.243-.97l-1 .25A1 1 0 0 0 8 6.89v4.306A2.6 2.6 0 0 0 7 11c-.5 0-.974.134-1.338.377-.36.24-.662.628-.662 1.123s.301.883.662 1.123c.364.243.839.377 1.338.377s.974-.134 1.338-.377c.36-.24.662-.628.662-1.123V8.89l2-.5z"/>
									<path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/>
								</svg>
							{% endif %}
							{% if fichier.format == 'Numérique' %}
								<span id="item-name" class="text-dark" title="{{ fichier.libellefichier }}">{{ fichier.libellefichier }}</span>
							{% elseif fichier.format == 'Physique' %}
								<span id="item-name" class="text-dark" title="{{ fichier.libellefichier }}">{{ fichier.libellefichier }}</span>
							{% endif %}
						</td>
						<td id="item-type" class="tables-last">{{ fichier.format }}
							|
							<span class="badge text-bg-dark">{{ fichier.type }}</span>
						</td>
						<td id="item-dep" class="tables-handle">{{ fichier.dossier.departement.libelleDep }}</td>
						{% if fichier.tags == null %}
							<td class="tables-tags fst-italic text-secondary">Aucun mot-clé</td>
						{% else %}
							<td id="item-kywd" class="tables-tags text-truncate" style="max-width:200px">{{ fichier.getFormattedTags }}</td>
						{% endif %}
						<td class="tables-date">{{ fichier.dateCreation|date('d/m/Y') }}</td>
						{% if fichier.statut %}
							<td class="tables-handle text-success">Disponible</td>
						{% else %}
							<td class="tables-handle text-danger">Indisponible</td>
						{% endif %}
						<td class="text-center">
							<span>
								<button type="button" id="btn-req-file" class="btn btn-outline-dark btn-sm rounded-sm text-center" {{ fichier.statut ? '' : 'disabled' }} style="font-size:13px;width:75%" data-bs-placement="top" data-bs-target="">
									<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="currentColor" class="bi bi-lock-fill mb-1" viewbox="0 0 16 16">
										<path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2m3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2"/>
									</svg>
									Demander accès
								</button>
							</span>
						</td>
					</tr>
				</td>
			</tr>
		{% endfor %}
	{% endif %}
</tbody></tbody></table></div>
