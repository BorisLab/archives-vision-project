<div class="modal fade text-start" id="previewFile" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-fullscreen">
		<div class="modal-content" id="modal-content-file">
			<div class="modal-header">
				<h5 class="modal-title" id="previewTitle" style="max-width: 250px;"></h5>
				<button type="download" id="preview-download-btn" class="btn btn-outline-dark btn-sm position-absolute mt-4 px-4 start-50 translate-middle" aria-label="">Télécharger ce fichier</button>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div>
				<div id="filePreviewContent" class="modal-body" style="display:flex;justify-content:center;align-items:center;overflow:hidden;"></div>
			</div>
		</div>
	</div>
</div>
