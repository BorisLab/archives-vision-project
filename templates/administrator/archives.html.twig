{% extends 'layouts/base.html.twig' %}

{% block title %}
	Fonds d'archives &middot;
	{{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}">

	<style>

		body {
			background-color: #f9fbfd;
			overflow-x: hidden;
		}

		input.form-control:focus,
		.form-select:focus {
			border-color: #0d6efd;
			outline: 0;
			box-shadow: 0 0 0 0;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="main-content">
		{{ include('layouts/partials/admin/_navbar-admin.html.twig')}}

		<div class="header">
			<div
				class="container">
				<!-- Body -->
				<div class="header-body border-bottom mt-4 mb-4" style="border-color:rgba(18, 38, 63, 0.175)">
					<div class="row align-items-end">
						<div
							class="col pb-3">

							<!-- Title -->
							<h4 class="header-title">
								Fonds d'archives
							</h1>

						</div>

					</div>
					<!-- / .row -->
				</div>
				<!-- / .header-body -->
			</div>
		</div>
	</div>
	<div class="container">
		<div class="row mb-3">
			<div class="col-md-4">
				<div class="mb-3">
					<label for="formGroupExampleInput" class="form-label">Rechercher</label>
					<input type="text" class="form-control" id="formGroupExampleInput" autofocus placeholder="Quel document recherchez-vous?">
				</div>
			</div>
			<div class="col-md-2">
				<div class="mb-3">
					<label for="formGroupExampleInput" class="form-label">Département</label>
					<input type="text" class="form-control" id="formGroupExampleInput" autofocus placeholder="Nom du département">
				</div>
			</div>
			<div class="col-md-2">
				<label for="inputSelect" class="form-label">Format</label>
				<select id="inputSelect" class="form-select">
					<option selected>--Choisir--</option>
					<option>Physique</option>
					<option>Numérique</option>
				</select>
			</div>
			<div class="col">
				<label for="dateMin" class="form-label">Du</label>
				<input type="date" id="dateMin" class="form-control" placeholder="Date minimale">
			</div>
			<div class="col">
				<label for="dateMax" class="form-label">Au</label>
				<input type="date" id="dateMax" class="form-control" placeholder="Date maximale">
			</div>

		</div>

		<div class="card mb-2">
			<div class="card-body text-center">
				<div class="row justify-content-center">
					<div
						class="col-12 col-xl-10">

						<!-- Image -->
						<img
						draggable="false" src="{{ asset('assets/imgs/empty-box.gif') }}" alt="..." class="img-fluid mb-4" style="max-width: 272px;">

						<!-- Title -->
						<h4 class="mb-2">
							Le fonds d'archives est vide
						</h4>

						<!-- Content -->
						<p class="text-muted">
							Tous les documents ajoutés s'afficheront ici.
						</p>

					</div>
				</div>
				<!-- / .row -->
			</div>
		</div>

	</div>

{% endblock %}
