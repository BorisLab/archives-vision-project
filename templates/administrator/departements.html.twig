											<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
										</div>
										<div class="modal-body">
											<form action="" method="post">
												<div class="mb-3">
													<label for="exampleFormControlInput1" class="form-label">Nom du département</label>
													<input type="text" readonly class="form-control" id="exampleFormControlInput1" placeholder="Entrer le nom du département">
												</div>

												<div class="mb-3">
													<label for="email1Group" class="form-label">Email</label>
													<div class="input-group mb-3">
														<input type="text" class="form-control" id="email1Group" placeholder="Préfixe de l'adresse" aria-label="Recipient's username" aria-describedby="basic-addon2">
														<span class="input-group-text" id="basic-addon2">@entreprise.com</span>
													</div>
												</div>
