{% extends 'layouts/base.html.twig' %}

{% block title %}
	Départements &middot;
	{{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}">

	<style>

		body {
			background-color: #f9fbfd;
			overflow-x: hidden;
		}

		input.form-control:focus,
		.form-select:focus {
			border-color: #0d6efd;
			outline: 0;
			box-shadow: 0 0 0 0;
		}

		#save {
			background-color: #fff;
			color: #2c7be5;
			font-size: smaller;
		}

		#save:hover {
			background-color: #2c7be5;
			color: #fff;
		}

		#cancel {
			font-size: smaller;
		}

		#cancel:hover {
			background-color: #6e84a3;
		}
	</style>
{% endblock %}

