				class="container">
				<!-- Body -->
				<div class="header-body border-bottom mt-4 mb-4" style="border-color:rgba(18, 38, 63, 0.175)">
					<div class="row align-items-end">
						<div
							class="col pb-3">

							<!-- Title -->
							<h4 class="header-title">
								Départements
							</h1>

						</div>
						<div
							class="col-auto pb-3">

							<!-- Button -->
							<a href="#!" draggable="false" class="btn btn-info lift" data-bs-toggle="modal" data-bs-target="#createDEP">
