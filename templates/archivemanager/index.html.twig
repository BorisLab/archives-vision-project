{% extends 'layouts/base.html.twig' %}

{% block title %}
	Accueil &middot;
	{{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/css/toasts.css') }}"/>
	<link rel="stylesheet" href="{{ asset('assets/css/scrollbar.css') }}">


	<style>

		body {
			background-color: #F9FBFD;
			overflow-x: hidden;
		}

		#notifcart:hover {
			background-color: #F1F1F1;
			box-shadow: 0 0 20px 2px #ECF2F3;
		}
	</style>

{% endblock %}

{% block body %}
	{{ include('layouts/partials/_logout-loading.html.twig') }}
	{{ include('layouts/partials/_loading.html.twig') }}

	<div class="main-content">
		{{ include('layouts/partials/archivman/_navbar-archivman.html.twig') }}

		<div class="header">
			<div
				class="container">

				<!-- Body -->
				<div class="header-body border-bottom mt-4" style="border-color:rgba(18, 38, 63, 0.175)">
					<div class="row align-items-end">
						<div
							class="col pb-3">

							<!-- Title -->
							<h4 class="header-title">
								Tableau de notifications
							</h4>

						</div>
					</div>
					<!-- / .row -->
				</div>
				<!-- / .header-body -->
			</div>
		</div>
	</div>
	<div class="container">
		<div class="row row-cols-1 row-cols-md-3 g-4">
			<div class="col-12 col-lg-6 col-xl">

				<a href="#" draggable="false" style="text-decoration:none">
					<div class="card border border-secondary-subtle" id="notifcart">
						<div class="card-body">
							<div class="row align-items-center gx-0">
								<div
									class="col">

									<!-- Title -->
									<h6 class="text-uppercase text-dark mb-2">
										Notifications non traitées
									</h6>

									<!-- Heading -->
									<span class="h2 text-dark mb-0">
										0
									</span>

								</div>
								<div
									class="col-auto">

									<!-- Icon -->
									<span class="h2">
										<box-icon color="#00000" type='solid' animation='tada-hover' name='flag'></box-icon>
									</span>

								</div>
							</div>
							<!-- / .row -->
						</div>
					</div>
				</a>

			</div>
			<div class="col-12 col-lg-6 col-xl">

				<a href="#" draggable="false" style="text-decoration:none">
					<div class="card border border-secondary-subtle" id="notifcart">
						<div class="card-body">
							<div class="row align-items-center gx-0">
								<div
									class="col">

									<!-- Title -->
									<h6 class="text-uppercase text-dark mb-2">
										Messages non lus
									</h6>

									<!-- Heading -->
									<span class="h2 text-dark mb-0">
										0
									</span>

								</div>
								<div
									class="col-auto">

									<!-- Icon -->
									<span class="h2">
										<box-icon color="#00000" type='solid' animation='tada-hover' name='envelope'></box-icon>
									</span>

								</div>
							</div>
							<!-- / .row -->
						</div>
					</div>
				</a>

			</div>

		</div>
		<div
			class="container">
			<!-- Body -->
			<div class="header-body border-bottom mt-4 mb-4" style="border-color:rgba(18, 38, 63, 0.175)">
				<div class="row align-items-end">
					<div
						class="col pb-3">

						<!-- Title -->
						<h4 class="header-title">
							Actions récentes
						</h4>

					</div>
				</div>
				<!-- / .row -->
			</div>
			<!-- / .header-body -->
		</div>
		<div class="card border border-secondary-subtle mb-2">
			<div class="card-body text-center">
				<div class="row justify-content-center">
					<div class="tab-content" id="myTabContent">
						<div class="tab-pane fade show active" id="docphys-tab-pane" role="tabpanel" aria-labelledby="docphys-tab" tabindex="0">
							<div
								class="col-12">

								<!-- Title -->
								<h4 class="mt-3 mb-2">
									Votre historique est vide
								</h4>

								<!-- Content -->
								<p class="text-muted">
									Toutes vos actions récentes s'affichent ici.
								</p>

							</div>
						</div>
						<div class="tab-pane fade" id="docnum-tab-pane" role="tabpanel" aria-labelledby="docnum-tab" tabindex="0">
							<div
								class="col-12">

								<!-- Image -->
								<img
								draggable="false" src="{{ asset('assets/imgs/empty-box.gif') }}" alt="..." class="img-fluid mb-4" style="max-width: 272px;">

								<!-- Title -->
								<h4 class="mb-2">
									Votre historique est vide
								</h4>

								<!-- Content -->
								<p class="text-muted">
									Évènements récents relatifs aux documents numériques.
								</p>

							</div>
						</div>
					</div>
				</div>
				<!-- / .row -->
			</div>
		</div>
		<div class="mt-4">
			{{ include('layouts/partials/_footer.html.twig')}}
		</div>
	</div>
	<div
		id="flash-msgs">
		<!-- Modals Toats -->
		{{ include('fonds_archives/composants/modals/toasts/_system.html.twig') }}
	</div>


{% endblock %}

{% block javascripts %}
	<script src="{{ asset('assets/js/shortcodes/_toasts.js') }}"></script>
{% endblock %}
