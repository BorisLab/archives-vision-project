{% extends 'layouts/base.html.twig' %}

{% block title %}
	Accueil &middot;
	{{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/css/toasts.css') }}"/>

	<style>

		body {
			background-color: #F9FBFD;
			overflow-x: hidden;
		}

		#notifcart:hover {
			background-color: #F1F1F1;
			box-shadow: 0 0 20px 2px #ECF2F3;
		}
	</style>

{% endblock %}

{% block body %}
	{{ include('layouts/partials/_logout-loading.html.twig') }}
	{{ include('layouts/partials/_loading.html.twig') }}

		{% for message in app.flashes('success') %}
			<div class="toast-container position-fixed bottom-0 end-0 p-3 mb-5" style="z-index: 1050;">
				<div class="toast" role="alert" aria-live="assertive" data-bs-animation="false" data-bs-delay="10000" style="box-shadow:none;" aria-atomic="true">
					<div class="toast-header text-success">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewbox="0 0 16 16">
							<path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
						</svg>
						<strong class="me-auto ms-2">Message de succès</strong>
						<button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
					</div>
					<div class="toast-body w-auto text-truncate" style="max-width:500px">
						{{ message }}
					</div>
				</div>
			</div>
		{% endfor %}

	<div class="main-content">
		{{ include('layouts/partials/archivman/_navbar-archivman.html.twig') }}

		<div class="header">
			<div
				class="container">

				<!-- Body -->
				<div class="header-body border-bottom mt-4" style="border-color:rgba(18, 38, 63, 0.175)">
					<div class="row align-items-end">
						<div
							class="col pb-3">

							<!-- Title -->
							<h4 class="header-title">
								Tableau de notifications
							</h4>

						</div>
					</div>
					<!-- / .row -->
				</div>
				<!-- / .header-body -->
			</div>
		</div>
	</div>
	<div class="container">
		<div class="row row-cols-1 row-cols-md-3 g-4">
			<div class="col-12 col-lg-6 col-xl">

				<a href="#" draggable="false" style="text-decoration:none">
					<div class="card border border-secondary-subtle" id="notifcart">
						<div class="card-body">
							<div class="row align-items-center gx-0">
								<div
									class="col">

									<!-- Title -->
									<h6 class="text-uppercase text-dark mb-2">
										Demandes non traitées
									</h6>

									<!-- Heading -->
									<span class="h2 text-dark mb-0">
										0
									</span>

								</div>
								<div
									class="col-auto">

									<!-- Icon -->
									<span class="h2">
										<box-icon color="#00000" type='solid' animation='tada-hover' name='flag'></box-icon>
									</span>

								</div>
							</div>
							<!-- / .row -->
						</div>
					</div>
				</a>

			</div>
			<div class="col-12 col-lg-6 col-xl">

				<a href="#" draggable="false" style="text-decoration:none">
					<div class="card border border-secondary-subtle" id="notifcart">
						<div class="card-body">
							<div class="row align-items-center gx-0">
								<div
									class="col">

									<!-- Title -->
									<h6 class="text-uppercase text-dark mb-2">
										Messages non lus
									</h6>

									<!-- Heading -->
									<span class="h2 text-dark mb-0">
										0
									</span>

								</div>
								<div
									class="col-auto">

									<!-- Icon -->
									<span class="h2">
										<box-icon color="#00000" type='solid' animation='tada-hover' name='envelope'></box-icon>
									</span>

								</div>
							</div>
							<!-- / .row -->
						</div>
					</div>
				</a>

			</div>

		</div>
		<div
			class="container">
			<!-- Body -->
			<div class="header-body border-bottom mt-4 mb-4" style="border-color:rgba(18, 38, 63, 0.175)">
				<div class="row align-items-end">
					<div
						class="col pb-3">

						<!-- Title -->
						<h4 class="header-title">
							Actions récentes
						</h4>

					</div>
				</div>
				<!-- / .row -->
			</div>
			<!-- / .header-body -->
		</div>
		<div class="card border border-secondary-subtle mb-2">
			<div class="card-body text-center">
				<div class="row justify-content-center">
					<div class="tab-content" id="myTabContent">
						<div class="tab-pane fade show active" id="docphys-tab-pane" role="tabpanel" aria-labelledby="docphys-tab" tabindex="0">
							<div
								class="col-12">

								<!-- Title -->
								<h4 class="mt-3 mb-2">
									Votre historique est vide
								</h4>

								<!-- Content -->
								<p class="text-muted">
									Toutes vos actions récentes s'affichent ici.
								</p>

							</div>
						</div>
						<div class="tab-pane fade" id="docnum-tab-pane" role="tabpanel" aria-labelledby="docnum-tab" tabindex="0">
							<div
								class="col-12">

								<!-- Image -->
								<img
								draggable="false" src="{{ asset('assets/imgs/empty-box.gif') }}" alt="..." class="img-fluid mb-4" style="max-width: 272px;">

								<!-- Title -->
								<h4 class="mb-2">
									Votre historique est vide
								</h4>

								<!-- Content -->
								<p class="text-muted">
									Évènements récents relatifs aux documents numériques.
								</p>

							</div>
						</div>
					</div>
				</div>
				<!-- / .row -->
			</div>
		</div>
		<div class="mt-4">
			{{ include('layouts/partials/_footer.html.twig')}}
		</div>
	</div>


{% endblock %}

{% block javascripts %}
	<script src="{{ asset('assets/js/shortcodes/_toasts.js') }}"></script>
{% endblock %}
