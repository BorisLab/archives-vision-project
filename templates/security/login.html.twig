{% extends 'layouts/base.html.twig' %}

{% block title %}
	Connexion &middot;
	{{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}"/>
	<link rel="stylesheet" href="{{ asset('assets/css/toasts.css') }}"/>
	<link href="{{ asset('build/app.css') }}" rel="stylesheet">
	<script src="{{ asset('build/app.js') }}"></script>

	<style>
		* {
			overflow: hidden;
		}
	</style>
{% endblock %}

{% block body %}
	{{ include('layouts/partials/_login-loading.html.twig') }}
	<div class="row">
		<div class="container mx-auto">
			<div class="bg-zinc-50 px-6 mt-20 mb-5 text-center dark:bg-neutral-700 dark:text-white">
				<h3 class="text-4xl font-bold">ARCHIVES VISION</h3>
			</div>
		</div>
		<div class="col-md-5 mx-auto">
			<h1 class="text-center">
				Accédez à votre compte
			</h1>
			<p class="mt-3 mb-3 text-center text-muted">
				Vos documents d'archives n'attendent que vous !
			</p>
			<form id="auth-form" method="post">
				{% if error %}
					{% for message in app.flashes('error') %}
						<div class="toast-container bottom-0 end-0 p-3 mb-5" style="z-index: 1050;">
							<div class="toast d-flex text-bg-dark flash-msg" role="alert" aria-live="assertive" data-bs-delay='10000' style="width:425px;box-shadow:none" aria-atomic="true">
								<div class="toast-body w-auto d-flex">
									<span class="text-danger mt-1 me-3">
										<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle-fill" viewbox="0 0 16 16">
											<path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
										</svg>
									</span>
									<span class="text-light text-truncate" style="max-width:400px">{{ message }}</span>
								</div>
							</div>
						</div>
					{% endfor %}
				{% endif %}

				{% if app.user %}
					<div class="mb-3">
						Vous êtes connecté en tant que
						{{ app.user.userIdentifier }},
						<a href="{{ path('app_logout') }}">Se déconnecter</a>
					</div>
				{% endif %}
				<div class="container">
					<div class="mb-3">
						<label for="inputEmail">Email</label>
						<input type="email" value="{{ last_username }}" name="email" id="inputEmail" placeholder="Entrez votre adresse email" class="form-control" autocomplete="email" required autofocus/>
					</div>

					<div class="mb-3">
						<label for="inputPassword">Mot de passe</label>
						<input type="password" name="password" id="inputPassword" placeholder="Entrez votre mot de passe" class="form-control" autocomplete="current-password" required/>
					</div>

					<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"/>

					<div class="mb-3 d-flex justify-content-between">
						<div class="form-check"></div>
						<a class="link-dark" href="passwordForget" data-bs-target="#passwordForget" draggable="false">Mot de passe oublié ?</a>
					</div>

					<div class="d-grid gap-2 mb-4">
						<button class="btn btn-lg btn-dark" type="submit">
							Se connecter
						</button>
					</div>
				</div>
			</form>
		</div>
	</div>
	<div class="b-example-divider"></div>

	<div>
		{{ include('layouts/partials/_footer.html.twig') }}
	</div>
{% endblock %}

{% block javascripts %}
	<script src="{{ asset('assets/js/shortcodes/_login-loading.js') }}"></script>
	<script src="{{ asset('assets/js/shortcodes/_toasts.js') }}"></script>
{% endblock %}
