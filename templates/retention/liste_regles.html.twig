{% extends 'layouts/base.html.twig' %}

{% block title %}Règles de rétention · {{ parent() }}
{% endblock %}

{% block stylesheets %}
	<link rel="stylesheet" href="{{ asset('assets/css/theme.bundle.css') }}">

	<style>
		body {
			background-color: #f9fbfd;
			overflow-x: hidden;
		}
	</style>
{% endblock %}

{% block body %}
{{ include('layouts/partials/_logout-loading.html.twig') }}
<div class="main-content">
	{{ include('layouts/partials/admin/_navbar-admin.html.twig') }}

	<div class="header">
		<div class="container">
			<div class="header-body border-bottom mt-4 mb-4" style="border-color:rgba(18, 38, 63, 0.175)">
				<div class="row align-items-end">
					<div class="col pb-3">
						<h4 class="header-title">
							<i class="bi bi-calendar-check"></i> Règles de rétention
						</h4>
					</div>
					<div class="col-auto pb-3">
						<a href="{{ path('app_retention_create') }}" class="btn btn-primary lift">
							<i class="bi bi-plus-circle"></i> Nouvelle règle
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="container">
	{% for message in app.flashes('success') %}
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			{{ message }}
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	{% endfor %}

	<div class="card shadow-sm">
			<div class="card-body">
				{% if regles|length > 0 %}
					<div class="table-responsive">
						<table class="table table-hover">
							<thead class="table-light">
								<tr>
									<th>Libellé</th>
									<th>Durée (années)</th>
									<th>Base légale</th>
									<th>Description</th>
									<th>Créée le</th>
									<th class="text-end">Actions</th>
								</tr>
							</thead>
							<tbody>
								{% for regle in regles %}
									<tr>
										<td>
											<strong>{{ regle.libelle }}</strong>
										</td>
										<td>
											<span class="badge bg-info">
												{{ regle.dureeConservation }}
												an(s)
											</span>
										</td>
										<td>
											<small class="text-muted">
												{{ regle.baseLegale|length > 80 ? regle.baseLegale|slice(0, 80) ~ '...' : regle.baseLegale }}
											</small>
										</td>
										<td>
											{% if regle.description %}
												<small class="text-muted">
													{{ regle.description|length > 50 ? regle.description|slice(0, 50) ~ '...' : regle.description }}
												</small>
											{% else %}
												<em class="text-muted">-</em>
											{% endif %}
										</td>
										<td>
											<small>{{ regle.createdAt|date('d/m/Y H:i') }}</small>
										</td>
										<td class="text-end">
											<div class="btn-group btn-group-sm">
												<a href="{{ path('app_retention_edit', {'id': regle.id}) }}" class="btn btn-outline-primary" title="Modifier">
													<i class="bi bi-pencil"></i>
												</a>
												<button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal{{ regle.id }}" title="Supprimer">
													<i class="bi bi-trash"></i>
												</button>
											</div>
										</td>
									</tr>

									{# Modal de confirmation de suppression #}
									<div class="modal fade" id="deleteModal{{ regle.id }}" tabindex="-1">
										<div class="modal-dialog">
											<div class="modal-content">
												<div class="modal-header">
													<h5 class="modal-title">Confirmer la suppression</h5>
													<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
												</div>
												<div class="modal-body">
													<p>Êtes-vous sûr de vouloir supprimer la règle
														<strong>{{ regle.libelle }}</strong>
														?</p>
													<p class="text-danger">
														<i class="bi bi-exclamation-triangle"></i>
														Cette action est irréversible.
													</p>
												</div>
												<div class="modal-footer">
													<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button>
													<form method="post" action="{{ path('app_retention_delete', {'id': regle.id}) }}" style="display: inline;">
														<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ regle.id) }}">
														<button type="submit" class="btn btn-danger">
															<i class="bi bi-trash"></i>
															Supprimer
														</button>
													</form>
												</div>
											</div>
										</div>
									</div>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% else %}
					<div class="text-center py-5">
						<i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
						<p class="text-muted mt-3">Aucune règle de rétention définie.</p>
						<a href="{{ path('app_retention_create') }}" class="btn btn-primary">
							<i class="bi bi-plus-circle"></i>
							Créer la première règle
						</a>
					</div>
				{% endif %}
			</div>
		</div>
	</div>
{% endblock %}
