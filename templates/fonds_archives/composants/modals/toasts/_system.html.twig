{% if 'success' %}

	{% for message in app.flashes('success') %}
		<div class="toast-container bottom-0 end-0 p-3 mb-5" style="z-index: 1050;">
			<div class="toast d-flex text-bg-dark flash-msg" role="alert" aria-live="assertive" data-bs-delay='10000' style="width:350px;box-shadow:none" aria-atomic="true">
				<div class="toast-body w-auto d-flex">
					<span class="text-success me-3">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewbox="0 0 16 16">
							<path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
						</svg>
					</span>
					<span class="text-light text-truncate" style="max-width:400px">{{ message|raw }}</span>
				</div>
			</div>
		</div>
	{% endfor %}

{% endif %}
