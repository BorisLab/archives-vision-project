<div class="modal fade" id="addFile" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-card">
		<div class="modal-content">
			<div class="modal-header">
				<h6 class="card-header-title" id="exampleModalLabel2" style="font-size:15px">Ajouter un/des fichiers</h6>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			{{ form_start(addFile, {'attr': {'id': 'upload_fichier'}}) }}
			<div class="modal-body">
				<div class="mb-3">
					<div id="drop-zone" class="rounded border-dark p-5 text-center" style="border-style:dashed">
						Drag files here or
						<span class="text-primary file-browse">browse</span>
						{{ form_widget(addFile.fichier, {'attr': {'style': 'display:none'}}) }}
					</div>
				</div>
				<div class="list-group">
					<div class="list-group-item">
						<div class="d-flex w-100 gap-10 justify-content-between">
							<span class="badge mt-3 mb-3 bg-dark" style="width:50px;height:50px;display:flex;align-items:center;justify-content:center">
								<strong>JPG</strong>
							</span>
							<div class="w-100 p-2 ps-4">
								<div class="d-flex w-100 justify-content-between">
									<strong class="mb-1">${file.name}</strong>
									<button type="button" class="btn btn-sm ml-2 abort-upload">&times;</button>
								</div>
								<div style="gap:15px">
									<p class="mb-0">
										<span>4 MB / 8 MB</span>
										•
										<span>Uploading...</span>
									</p>
									<div class="progress mt-2" style="width: 100%;height: 5px">
										<div class="progress-bar" role="progressbar" style="width: 0%"></div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="row modal-footer">
				<div id="upload-status"></div>
				<div class="col" style="align-items:center">
					<button type="submit" class="btn btn-primary w-200 mt-3" style="display:flex;width:100%;justify-content:center" formnovalidate>Upload Files</button>
				</div>
			</div>
			{{ form_end(addFile) }}
		</div>
	</div>
</div>
